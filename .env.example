# Copilot SDK / LLM 추출 서버(/api/extract) 설정
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요. (.env 는 커밋 금지)

# 둘 중 하나만 있어도 됩니다. (우선순위: COPILOT_API_KEY > OPENAI_API_KEY > GITHUB_TOKEN)
COPILOT_API_KEY=
# OPENAI_API_KEY=
# GITHUB_TOKEN=

# OpenAI 호환 Chat Completions 엔드포인트의 베이스 URL.
# 기본값: https://api.openai.com/v1
# GitHub Models 사용 시 예: https://models.inference.ai.azure.com
COPILOT_BASE_URL=https://api.openai.com/v1

# 사용할 모델명 (기본값: gpt-4o-mini)
COPILOT_MODEL=gpt-4o-mini

# true 로 두면 LLM 호출을 건너뛰고 오프라인 휴리스틱 파서만 사용합니다.
MOCK_LLM=false
